---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTopLevelAreas, getTrails, getPOIs, getChildAreas, getTrailsForArea } from '../lib/data';

const topAreas = getTopLevelAreas();
const trails = getTrails();
const pois = getPOIs();

// Build area tree for sidebar
const areaTree = topAreas.map(area => ({
  ...area,
  children: getChildAreas(area.slug).filter(a => a.type !== 'access'),
  trailCount: getTrailsForArea(area.slug).length,
}));

// Build trail metadata lookup for client-side filtering
const trailMeta = Object.fromEntries(trails.map(t => [t.slug, {
  type: t.type,
  difficulty: t.difficulty || 'unknown',
  surface: t.surface || 'unknown',
  tags: t.tags || [],
}]));

// Collect all unique tags
const allTrailTags = [...new Set(trails.flatMap(t => t.tags || []))].sort();
const allPoiTags = [...new Set(pois.flatMap(p => p.tags || []))].sort();
const allTags = [...new Set([...allTrailTags, ...allPoiTags])].sort();
---

<BaseLayout title="Trail Map" fullWidth>
  <div class="h-[calc(100vh-56px)] flex flex-col md:flex-row">
    <!-- Sidebar -->
    <aside id="sidebar" class="
      w-full md:w-[360px] bg-white border-r border-stone-200
      flex flex-col order-2 md:order-1
      max-h-[40vh] md:max-h-full overflow-hidden z-[500] relative
    ">
      <div class="p-4 border-b border-stone-200 flex-shrink-0">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input id="search" type="text" aria-label="Search trails and areas" placeholder="Search trails, areas..." 
            class="w-full pl-9 pr-3 py-2 text-sm border border-stone-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent" />
        </div>
      </div>

      <!-- Filter Panel -->
      <div id="filter-panel" class="border-b border-stone-200 flex-shrink-0">
        <button id="filter-toggle" class="w-full px-4 py-2.5 flex items-center justify-between text-sm font-medium text-stone-700 hover:bg-stone-50 transition-colors">
          <span class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
            Filters
            <span id="filter-badge" class="hidden px-1.5 py-0.5 text-xs rounded-full bg-forest-600 text-white font-bold">0</span>
          </span>
          <svg id="filter-chevron" class="w-4 h-4 text-stone-400 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        <div id="filter-sections" class="hidden px-4 pb-3 space-y-2 max-h-[50vh] overflow-y-auto">
          <!-- Trail Level -->
          <div class="filter-category">
            <button class="filter-cat-toggle w-full flex items-center justify-between py-1.5 text-xs font-semibold text-stone-500 uppercase tracking-wider">
              Trail Level
              <svg class="w-3 h-3 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <div class="filter-cat-body flex flex-wrap gap-1.5 pb-2">
              {['official', 'unofficial', 'greenway', 'fire-road', 'connector', 'social', 'bushwhack'].map(v => (
                <label class="filter-chip cursor-pointer">
                  <input type="checkbox" class="hidden" data-filter-cat="level" value={v} />
                  <span class="inline-block px-2.5 py-1 text-xs rounded-full border border-stone-300 text-stone-600 hover:border-forest-500 hover:text-forest-700 transition-colors select-none">
                    {{ official: 'Official', unofficial: 'Unofficial', greenway: 'Greenway', 'fire-road': 'Fire Road', connector: 'Connector', social: 'Social', bushwhack: 'Bushwhack' }[v]}
                  </span>
                </label>
              ))}
            </div>
          </div>
          <!-- Difficulty -->
          <div class="filter-category">
            <button class="filter-cat-toggle w-full flex items-center justify-between py-1.5 text-xs font-semibold text-stone-500 uppercase tracking-wider">
              Difficulty
              <svg class="w-3 h-3 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <div class="filter-cat-body flex flex-wrap gap-1.5 pb-2">
              {['easy', 'moderate', 'difficult'].map(v => (
                <label class="filter-chip cursor-pointer">
                  <input type="checkbox" class="hidden" data-filter-cat="difficulty" value={v} />
                  <span class="inline-block px-2.5 py-1 text-xs rounded-full border border-stone-300 text-stone-600 hover:border-forest-500 hover:text-forest-700 transition-colors select-none capitalize">{v}</span>
                </label>
              ))}
            </div>
          </div>
          <!-- Surface -->
          <div class="filter-category">
            <button class="filter-cat-toggle w-full flex items-center justify-between py-1.5 text-xs font-semibold text-stone-500 uppercase tracking-wider">
              Surface
              <svg class="w-3 h-3 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <div class="filter-cat-body flex flex-wrap gap-1.5 pb-2">
              {['paved', 'gravel', 'dirt', 'rock', 'mixed'].map(v => (
                <label class="filter-chip cursor-pointer">
                  <input type="checkbox" class="hidden" data-filter-cat="surface" value={v} />
                  <span class="inline-block px-2.5 py-1 text-xs rounded-full border border-stone-300 text-stone-600 hover:border-forest-500 hover:text-forest-700 transition-colors select-none capitalize">{v}</span>
                </label>
              ))}
            </div>
          </div>
          <!-- POI Type -->
          <div class="filter-category">
            <button class="filter-cat-toggle w-full flex items-center justify-between py-1.5 text-xs font-semibold text-stone-500 uppercase tracking-wider">
              POI Type
              <svg class="w-3 h-3 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <div class="filter-cat-body flex flex-wrap gap-1.5 pb-2">
              {['historic', 'ruins', 'water', 'bridge', 'natural', 'campsite', 'overlook', 'sign'].map(v => (
                <label class="filter-chip cursor-pointer">
                  <input type="checkbox" class="hidden" data-filter-cat="poi" value={v} />
                  <span class="inline-block px-2.5 py-1 text-xs rounded-full border border-stone-300 text-stone-600 hover:border-forest-500 hover:text-forest-700 transition-colors select-none capitalize">{v}</span>
                </label>
              ))}
            </div>
          </div>
          <!-- Tags -->
          {allTags.length > 0 && (
            <div class="filter-category">
              <button class="filter-cat-toggle w-full flex items-center justify-between py-1.5 text-xs font-semibold text-stone-500 uppercase tracking-wider">
                Tags
                <svg class="w-3 h-3 transition-transform rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </button>
              <div class="filter-cat-body flex flex-wrap gap-1.5 pb-2">
                {allTags.map(tag => (
                  <label class="filter-chip cursor-pointer">
                    <input type="checkbox" class="hidden" data-filter-cat="tags" value={tag} />
                    <span class="inline-block px-2.5 py-1 text-xs rounded-full border border-stone-300 text-stone-600 hover:border-forest-500 hover:text-forest-700 transition-colors select-none">{tag}</span>
                  </label>
                ))}
              </div>
            </div>
          )}
          <!-- Clear all -->
          <button id="clear-filters" class="w-full text-xs text-forest-600 hover:text-forest-800 py-1 hidden">Clear all filters</button>
        </div>
      </div>

      <div id="results-list" class="flex-1 overflow-y-auto">
        {areaTree.map(area => (
          <div class="area-group" data-area={area.slug}>
            <button class="area-header w-full text-left px-4 py-3 bg-stone-50 border-b border-stone-200 hover:bg-stone-100 transition-colors flex items-center justify-between"
                    data-center={JSON.stringify(area.center)} data-zoom={area.default_zoom || 13}>
              <div>
                <div class="font-medium text-stone-800 text-sm">{area.name}</div>
                <div class="text-xs text-stone-500">{area.trailCount} trails</div>
              </div>
              <svg class="w-4 h-4 text-stone-400 area-chevron transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
            <div class="area-trails hidden">
              {trails.filter(t => t.areas?.some(a => a === area.slug || area.children?.some(c => c.slug === a))).map(trail => (
                <a href={`/trails/${trail.slug}`}
                   class="trail-item w-full text-left px-4 py-2.5 border-b border-stone-100 hover:bg-forest-50 transition-colors flex items-center gap-3 block"
                   data-trail={trail.slug} data-type={trail.type} data-difficulty={trail.difficulty || 'unknown'} data-surface={trail.surface || 'unknown'} data-tags={(trail.tags || []).join(',')}>
                  <span class={`w-2 h-2 rounded-full flex-shrink-0 ${
                    trail.type === 'official' ? 'bg-forest-600' :
                    trail.type === 'greenway' ? 'bg-forest-400' :
                    trail.type === 'fire-road' ? 'bg-trail-700' :
                    'bg-forest-300'
                  }`}></span>
                  <div class="min-w-0">
                    <div class="text-sm text-stone-800 truncate">{trail.name}</div>
                    <div class="text-xs text-stone-500">
                      {trail.distance_miles ? `${trail.distance_miles} mi · ` : ''}{trail.difficulty || 'unknown'} · {trail.loop ? 'loop' : 'out & back'}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </aside>

    <!-- Map -->
    <div id="map" class="flex-1 order-1 md:order-2 min-h-[60vh] md:min-h-0 z-[100]"></div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ pois, trailMeta }}>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof L === 'undefined') return;

    // --- Filter State ---
    const filterState = { level: [], difficulty: [], surface: [], poi: [], tags: [] };
    let trailGeoJSONLayer = null;
    const poiMarkers = [];

    // --- Read URL params ---
    function readFiltersFromURL() {
      const params = new URLSearchParams(window.location.search);
      ['level', 'difficulty', 'surface', 'poi', 'tags'].forEach(cat => {
        const val = params.get(cat);
        filterState[cat] = val ? val.split(',').filter(Boolean) : [];
      });
    }

    // --- Write URL params ---
    function writeFiltersToURL() {
      const params = new URLSearchParams();
      let hasAny = false;
      ['level', 'difficulty', 'surface', 'poi', 'tags'].forEach(cat => {
        if (filterState[cat].length > 0) {
          params.set(cat, filterState[cat].join(','));
          hasAny = true;
        }
      });
      const url = hasAny ? `${window.location.pathname}?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', url);
    }

    // --- Sync checkboxes to state ---
    function syncCheckboxes() {
      document.querySelectorAll('[data-filter-cat]').forEach(cb => {
        cb.checked = filterState[cb.dataset.filterCat]?.includes(cb.value) || false;
        updateChipStyle(cb);
      });
    }

    function updateChipStyle(cb) {
      const span = cb.nextElementSibling;
      if (cb.checked) {
        span.classList.add('bg-forest-600', 'text-white', 'border-forest-600');
        span.classList.remove('text-stone-600', 'border-stone-300');
      } else {
        span.classList.remove('bg-forest-600', 'text-white', 'border-forest-600');
        span.classList.add('text-stone-600', 'border-stone-300');
      }
    }

    // --- Update badge ---
    function updateBadge() {
      const total = Object.values(filterState).reduce((s, a) => s + a.length, 0);
      const badge = document.getElementById('filter-badge');
      const clearBtn = document.getElementById('clear-filters');
      if (total > 0) {
        badge.textContent = total;
        badge.classList.remove('hidden');
        clearBtn.classList.remove('hidden');
      } else {
        badge.classList.add('hidden');
        clearBtn.classList.add('hidden');
      }
    }

    // --- Check if trail passes filters ---
    function trailPassesFilter(slug) {
      const meta = trailMeta[slug];
      if (!meta) return true; // unknown trails pass
      const { level, difficulty, surface, tags } = filterState;
      if (level.length > 0 && !level.includes(meta.type)) return false;
      if (difficulty.length > 0 && !difficulty.includes(meta.difficulty)) return false;
      if (surface.length > 0 && !surface.includes(meta.surface)) return false;
      if (tags.length > 0 && !tags.some(t => meta.tags.includes(t))) return false;
      return true;
    }

    // --- Check if POI passes filters ---
    function poiPassesFilter(poi) {
      const { poi: poiTypes, tags } = filterState;
      if (poiTypes.length > 0 && !poiTypes.includes(poi.type)) return false;
      if (tags.length > 0 && !tags.some(t => (poi.tags || []).includes(t))) return false;
      return true;
    }

    // --- Apply all filters ---
    function applyFilters() {
      // Sidebar trail items
      document.querySelectorAll('.trail-item').forEach(item => {
        const slug = item.dataset.trail;
        item.style.display = trailPassesFilter(slug) ? '' : 'none';
      });
      // Hide area groups with no visible trails
      document.querySelectorAll('.area-group').forEach(group => {
        const items = group.querySelectorAll('.trail-item');
        const anyVisible = Array.from(items).some(i => i.style.display !== 'none');
        group.style.display = anyVisible ? '' : 'none';
      });
      // GeoJSON layers
      if (trailGeoJSONLayer) {
        trailGeoJSONLayer.eachLayer(layer => {
          const trail = layer.feature?.properties?.trail;
          if (!trail) {
            // Unnamed segments: show if no trail-level filters active
            const hasTrailFilters = filterState.level.length > 0 || filterState.difficulty.length > 0 || filterState.surface.length > 0 || filterState.tags.length > 0;
            layer.getElement && layer.getElement() ? layer.getElement().style.display = hasTrailFilters ? 'none' : '' : null;
            if (layer.setStyle) layer.setStyle({ opacity: hasTrailFilters ? 0 : 0.7 });
            return;
          }
          const visible = trailPassesFilter(trail);
          if (layer.setStyle) layer.setStyle({ opacity: visible ? 0.9 : 0 });
          if (layer.getElement && layer.getElement()) layer.getElement().style.pointerEvents = visible ? 'auto' : 'none';
        });
      }
      // POI markers
      poiMarkers.forEach(({ marker, poi }) => {
        const visible = poiPassesFilter(poi);
        if (visible) marker.addTo(map);
        else map.removeLayer(marker);
      });
      updateBadge();
      writeFiltersToURL();
    }

    // --- Filter toggle ---
    document.getElementById('filter-toggle').addEventListener('click', () => {
      const sections = document.getElementById('filter-sections');
      const chevron = document.getElementById('filter-chevron');
      sections.classList.toggle('hidden');
      chevron.classList.toggle('rotate-90');
    });

    // Category collapse
    document.querySelectorAll('.filter-cat-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const body = btn.nextElementSibling;
        const chevron = btn.querySelector('svg');
        body.classList.toggle('hidden');
        chevron.classList.toggle('rotate-90');
      });
    });

    // Checkbox change
    document.querySelectorAll('[data-filter-cat]').forEach(cb => {
      cb.addEventListener('change', () => {
        const cat = cb.dataset.filterCat;
        if (cb.checked) {
          if (!filterState[cat].includes(cb.value)) filterState[cat].push(cb.value);
        } else {
          filterState[cat] = filterState[cat].filter(v => v !== cb.value);
        }
        updateChipStyle(cb);
        applyFilters();
      });
    });

    // Clear all
    document.getElementById('clear-filters').addEventListener('click', () => {
      Object.keys(filterState).forEach(k => filterState[k] = []);
      syncCheckboxes();
      applyFilters();
    });

    // --- Map Setup ---
    const map = L.map('map', { zoomControl: true }).setView([36.077, -79.007], 15);
    const baseLayers = {
      'None': L.tileLayer('', { maxZoom: 20 }),
      'Satellite': L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
        maxZoom: 19, attribution: '© Esri, Maxar, Earthstar Geographics',
      }),
      'Esri Terrain': L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Terrain_Base/MapServer/tile/{z}/{y}/{x}', {
        maxZoom: 13, attribution: '© Esri, USGS, NOAA',
      }),
      'Topo': L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', {
        maxZoom: 17, attribution: '© OpenStreetMap contributors, SRTM | Map: © OpenTopoMap (CC-BY-SA)',
      }),
      'Clean (no labels)': L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png', {
        maxZoom: 20, attribution: '© OpenStreetMap contributors, © CARTO',
      }),
      'Dark': L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
        maxZoom: 20, attribution: '© OpenStreetMap contributors, © CARTO',
      }),
      'Esri Topo': L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}', {
        maxZoom: 19, attribution: '© Esri, HERE, Garmin, OpenStreetMap contributors',
      }),
      'USGS Topo': L.tileLayer('https://basemap.nationalmap.gov/arcgis/rest/services/USGSTopo/MapServer/tile/{z}/{y}/{x}', {
        maxZoom: 16, attribution: '© USGS',
      }),
    };
    baseLayers['Satellite'].addTo(map);
    L.control.layers(baseLayers, null, { position: 'topright' }).addTo(map);

    // Load trail geometry
    fetch('/trails.geojson')
      .then(r => r.json())
      .then(geojson => {
        const trailColors = {
          'cox-mountain-trail': '#e63946',
          'buckquarter-creek-trail': '#457b9d',
          'fannys-ford-trail': '#2a9d8f',
          'holdens-mill-trail': '#e9c46a',
          'ridge-trail': '#f4a261',
          'knight-trail': '#264653',
          'fieldstone-trail': '#6a4c93',
          'shakori-trail': '#1d3557',
        };

        trailGeoJSONLayer = L.geoJSON(geojson, {
          style: function(feature) {
            const trail = feature.properties.trail || '';
            const isUnnamed = !trail;
            return {
              color: isUnnamed ? '#ff6b6b' : (trailColors[trail] || '#4a7c28'),
              weight: isUnnamed ? 2.5 : 3.5,
              opacity: isUnnamed ? 0.7 : 0.9,
              dashArray: isUnnamed ? '6 4' : (feature.properties.informal === 'yes' ? '6 4' : null),
            };
          },
          onEachFeature: function(feature, layer) {
            const p = feature.properties;
            const trailSlug = p.trail || '';
            const name = p.name || trailSlug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) || 'Unnamed trail';
            layer.bindTooltip(name, { sticky: true });
            if (trailSlug) {
              const popupHtml = `<div style="min-width:120px"><strong>${name}</strong><br><a href="/trails/${trailSlug}" style="color:#2d5016;font-size:13px">View trail details →</a></div>`;
              layer.bindPopup(popupHtml);
            }
          }
        }).addTo(map);

        // Apply filters after GeoJSON loads
        applyFilters();
      })
      .catch(err => console.warn('Could not load trail geometry:', err));

    // POIs
    const poiIcons = {
      historic: '🏛️', natural: '🌿', bridge: '🌉',
      campsite: '⛺', overlook: '👁️', ruins: '🧱', water: '💧', sign: '📋',
    };

    pois.forEach(poi => {
      const icon = L.divIcon({
        html: `<span class="text-lg">${poiIcons[poi.type] || '📍'}</span>`,
        className: 'poi-marker',
        iconSize: [24, 24],
        iconAnchor: [12, 12],
      });
      const marker = L.marker([poi.lat, poi.lng], { icon });
      marker.bindTooltip(poi.name, { direction: 'top', offset: [0, -8] });

      const typeLabel = {
        historic: 'Historic Site', ruins: 'Ruins', bridge: 'Bridge',
        water: 'Water', sign: 'Info', natural: 'Natural', campsite: 'Campsite', overlook: 'Overlook',
      }[poi.type] || poi.type;
      const desc = poi.description ? `<br><span style="font-size:12px;color:#666">${poi.description.substring(0, 100)}${poi.description.length > 100 ? '...' : ''}</span>` : '';
      const popupHtml = `<div style="min-width:140px"><strong>${poi.name}</strong><br><span style="font-size:11px;color:#888">${typeLabel}</span>${desc}<br><a href="/pois/${poi.slug}" style="color:#2d5016;font-size:13px">View details →</a></div>`;
      marker.bindPopup(popupHtml);
      marker.addTo(map);
      poiMarkers.push({ marker, poi });
    });

    // --- Init from URL ---
    readFiltersFromURL();
    syncCheckboxes();
    applyFilters();
    // If filters are active on load, open the panel
    if (Object.values(filterState).some(a => a.length > 0)) {
      document.getElementById('filter-sections').classList.remove('hidden');
      document.getElementById('filter-chevron').classList.add('rotate-90');
    }

    // Area expand/collapse + map pan
    document.querySelectorAll('.area-header').forEach(header => {
      header.addEventListener('click', () => {
        const group = header.closest('.area-group');
        const trailsDiv = group.querySelector('.area-trails');
        const chevron = header.querySelector('.area-chevron');
        trailsDiv.classList.toggle('hidden');
        chevron.classList.toggle('rotate-90');
        try {
          const center = JSON.parse(header.dataset.center);
          const zoom = parseInt(header.dataset.zoom);
          if (center) map.flyTo(center, zoom);
        } catch(e) {}
      });
    });

    // Search
    document.getElementById('search').addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase().trim();
      document.querySelectorAll('.area-group').forEach(group => {
        const areaName = group.querySelector('.font-medium').textContent.toLowerCase();
        const items = group.querySelectorAll('.trail-item');
        let anyMatch = false;
        items.forEach(item => {
          // Respect both search AND filters
          if (item.style.display === 'none' && !q) return;
          const name = item.querySelector('.text-sm').textContent.toLowerCase();
          const passesFilter = trailPassesFilter(item.dataset.trail);
          const matchesSearch = !q || name.includes(q) || areaName.includes(q);
          const show = passesFilter && matchesSearch;
          item.style.display = show ? '' : 'none';
          if (show && q) anyMatch = true;
        });
        group.style.display = (!q || areaName.includes(q) || anyMatch) ? '' : 'none';
        if (q && anyMatch) {
          group.querySelector('.area-trails').classList.remove('hidden');
          group.querySelector('.area-chevron').classList.add('rotate-90');
        }
      });
    });
  });
</script>

